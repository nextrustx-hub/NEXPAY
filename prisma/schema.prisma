generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String
  name             String
  cpf              String?
  role             String   @default("WHITE") // WHITE or BLACK
  kyc_status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  two_factor_enabled Boolean @default(false)
  two_factor_secret   String?
  webhook_url      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  balances     Balance[]
  transactions Transaction[]
  checkoutLinks CheckoutLink[]
  apiKeys       ApiKey[]
}

model CheckoutLink {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String   @default("")
  currency    String
  amount      Float
  status      String   @default("active")
  paymentUrl  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  key       String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Balance {
  id        String   @id @default(cuid())
  userId    String
  currency  String   // BRL, EUR, USDT, BTC
  amount    Float    @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
}

model Transaction {
  id            String   @id @default(cuid())
  userId        String
  type          String   // deposit, withdraw, swap
  method        String?  // PIX, etc.
  currencyFrom  String?
  amountFrom    Float?
  currencyTo    String?
  amountTo      Float?
  pixKey        String?
  status        String   @default("pending") // pending, completed, failed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
